generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String
  email     String   @unique
  avatarUrl String?
  timeZone  String   @default("America/Toronto")
  reminderPreferences Json?   // Stores email/SMS reminder settings + custom messages
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventTypes EventType[]
  schedules  Schedule[]
  bookings   Booking[]
  webhooks   Webhook[]
  consents   Law25Consent[]
  outlookAccount OutlookAccount?

  @@schema("public")
}

model EventType {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String   @unique
  description String?
  length      Int      @default(30)
  location    String   @default("google-meet")
  color       String   @default("#242424")
  isActive    Boolean  @default(true)
  minNotice   Int      @default(60)
  bufferBefore Int     @default(0)
  bufferAfter  Int     @default(0)
  maxPerDay    Int?
  price        Int      @default(0)
  currency     String   @default("cad")
  isPrivate    Boolean  @default(false)
  meetingUrl   String?
  scheduleId   String?
  createdAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  bookings Booking[]
  schedule Schedule? @relation(fields: [scheduleId], references: [id])

  @@index([userId])
  @@index([slug])
  @@schema("public")
}

model Schedule {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Heures de travail")
  timeZone  String   @default("America/Toronto")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id])
  intervals Availability[]
  eventTypes EventType[]

  @@index([userId])
  @@schema("public")
}

model Availability {
  id         String   @id @default(cuid())
  scheduleId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)

  schedule Schedule @relation(fields: [scheduleId], references: [id])

  @@index([scheduleId])
  @@schema("public")
}

model Booking {
  id          String   @id @default(cuid())
  eventTypeId String
  userId      String
  attendeeId  String?
  guestName   String
  guestEmail  String
  guestNotes  String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("confirmed") 
  paymentMethod String? @default("STRIPE")
  paymentStatus String? @default("PAID")
  interacRef  String?  @unique
  cancelToken String   @default(cuid())
  paid         Boolean  @default(false)
  meetingUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventType EventType @relation(fields: [eventTypeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  attendee  Attendee? @relation(fields: [attendeeId], references: [id])
  auditLogs AuditLog[]

  @@index([eventTypeId])
  @@index([userId])
  @@index([startTime])
  @@index([interacRef])
  @@schema("public")
}

model Attendee {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  locale    String    @default("fr")
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@schema("public")
}

model AuditLog {
  id        String   @id @default(cuid())
  bookingId String?
  action    String
  actor     String
  ipAddress String
  timestamp DateTime @default(now())

  booking   Booking? @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@schema("public")
}

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  url       String
  events    String   @default("booking.created,booking.cancelled")
  isActive  Boolean  @default(true)
  secret    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@schema("public")
}

model Law25Consent {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentVersion        String
  dataCollectionAllowed Boolean  @default(false)
  crossBorderAllowed    Boolean  @default(false)
  ipAddress             String
  timestamp             DateTime @default(now())

  @@index([userId])
  @@schema("public")
}

model OutlookAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  email              String
  
  accessToken        String   @db.Text
  refreshToken       String   @db.Text
  tokenExpiresAt     DateTime 
  
  nextDeltaLink      String?  @db.Text
  deltaLinkUpdatedAt DateTime?
  
  anchorTimezone     String   @default("UTC")
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model VoiceAgentConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  agentId     String   // ElevenLabs agent ID
  agentName   String   @default("Planxo Scheduler")
  systemPrompt String? @db.Text
  voiceId     String?
  language    String   @default("en")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model VoiceAgentConversation {
  id              String   @id @default(cuid())
  userId          String
  agentId         String
  conversationId  String   // ElevenLabs conversation ID
  transcript      Json     @default("[]") // Array of {role, text, timestamp}
  status          String   @default("active") // active, completed, failed
  startTime       DateTime @default(now())
  endTime         DateTime?
  metadata        Json?    // Additional context

  @@index([userId])
  @@index([agentId])
  @@index([conversationId])
  @@schema("public")
}

